#include <windows.h>

// System Version Information Block
VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0" // Language: US English (0x0409), Character Set: Unicode (1200 / 0x04b0)
        BEGIN
            VALUE "CompanyName",      "MezoDawnHorizon"
            VALUE "FileDescription",  "Dynamic Cursor Overlay"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "DynamicCursor"
            VALUE "LegalCopyright",   "Copyright (C) 2026"
            VALUE "OriginalFilename", "DynamicCursor.exe"
            VALUE "ProductName",      "Dynamic Cursor"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END